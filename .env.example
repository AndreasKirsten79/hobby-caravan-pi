# ============================================================
# Kopiere diese Datei nach .env und fülle alle Werte aus.
# Die .env Datei wird NICHT ins Git eingecheckt (steht in .gitignore).
# ============================================================

# Tailscale Auth-Key (einmalig, unter tailscale.com/settings/keys erzeugen)
TS_AUTHKEY=tskey-auth-XXXXXXXXXXXXXXXXXXXX

# Passwörter für die lokalen Dienste (frei wählbar)
INFLUXDB_PASSWORD=sicheres_passwort_hier
GRAFANA_PASSWORD=sicheres_passwort_hier
MYSQL_ROOT_PASSWORD=sicheres_passwort_hier
MYSQL_PASSWORD=sicheres_passwort_hier
